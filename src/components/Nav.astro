---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/players', label: 'Players' },
  { href: '/services', label: 'Services' },
  { href: '/media', label: 'Media' },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<nav class="nav" id="site-nav" aria-label="Main">
  <div class="nav__in">
    <a href="/" class="nav__brand" aria-label="ProKickTalent home">
      <svg width="24" height="24" viewBox="0 0 32 32" aria-hidden="true">
        <path d="M3 27 Q 16 -1 29 27" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-dasharray="2.5 3"></path>
        <circle cx="16" cy="6" r="3.5" fill="currentColor"></circle>
      </svg>
      <b>ProKickTalent</b>
    </a>

    <div class="nav__links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="nav__link"
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <a href="/contact" class="nav__cta">Start an evaluation</a>

    <button class="nav__toggle" id="theme-toggle" type="button" aria-label="Toggle light/dark theme">◐&nbsp;light</button>

    <button class="nav__burger" id="nav-burger" type="button" aria-label="Toggle menu" aria-expanded="false">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <div class="nav__mobile" id="nav-mobile">
    {navLinks.map((link) => (
      <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>
    ))}
    <a href="/contact">Start an evaluation</a>
  </div>
</nav>

<script is:inline>
  (function () {
    const nav = document.getElementById('site-nav');
    const root = document.documentElement;
    const toggle = document.getElementById('theme-toggle');
    const burger = document.getElementById('nav-burger');
    const mobile = document.getElementById('nav-mobile');

    // reflect current theme on the toggle label (theme already applied in <head>)
    const sync = () => {
      const dark = root.getAttribute('data-theme') === 'dark';
      if (toggle) toggle.innerHTML = dark ? '◐&nbsp;dark' : '◐&nbsp;light';
    };
    sync();

    toggle?.addEventListener('click', () => {
      const dark = root.getAttribute('data-theme') !== 'dark';
      if (dark) root.setAttribute('data-theme', 'dark');
      else root.removeAttribute('data-theme');
      try { localStorage.setItem('pkt-theme', dark ? 'dark' : 'light'); } catch (e) {}
      sync();
    });

    burger?.addEventListener('click', () => {
      const open = mobile.getAttribute('data-open') === 'true';
      mobile.setAttribute('data-open', String(!open));
      burger.setAttribute('aria-expanded', String(!open));
    });

    const onScroll = () => nav.setAttribute('data-scrolled', String(window.scrollY > 16));
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
