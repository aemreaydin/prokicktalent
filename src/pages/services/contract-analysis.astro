---
import Layout from '../../layouts/Layout.astro';

const clauses = [
  { no: '§ 4.2', name: 'Term & option years', note: 'Two-year term with two club-side option years. Standard, but the options are unilateral — the club controls four years total.', status: 'clear', label: 'Clear' },
  { no: '§ 5.1', name: 'Wage structure & bonuses', note: 'Base wage in line with league scale for the age band. Appearance bonuses defined and reasonable.', status: 'clear', label: 'Clear' },
  { no: '§ 6.4', name: 'Image rights', note: "Club claims 100% of commercial image rights with no carve-out for the player's personal sponsors. Needs negotiation.", status: 'review', label: 'Review' },
  { no: '§ 7.2', name: 'Release / buyout clause', note: 'No fixed release clause. For a player on this trajectory, a defined buyout protects future mobility — recommend adding one.', status: 'review', label: 'Review' },
  { no: '§ 8.1', name: 'Performance bonuses', note: 'Promotion and call-up bonuses clearly defined. Achievable and well-structured.', status: 'clear', label: 'Clear' },
  { no: '§ 9.5', name: 'Solidarity contribution', note: "Clause waives the player's former-club solidarity entitlement under FIFA RSTP. Non-standard and disadvantages the development chain. Flag for removal.", status: 'flag', label: 'Flag' },
];
const terms = [
  { k: 'Term', v: '2 + 2 yrs', flag: false },
  { k: 'Base wage', v: 'on scale', flag: false },
  { k: 'Image rights', v: '100% club', flag: true },
  { k: 'Release clause', v: 'none', flag: true },
  { k: 'Solidarity', v: 'waived', flag: true },
];
const steps = [
  { n: '01', title: 'Plain-language read', body: "Every clause translated out of legal language so the player and family understand exactly what they're agreeing to." },
  { n: '02', title: 'Flag & benchmark', body: 'Each term checked against league scale, age band, and FIFA regulations. Anything below standard gets flagged with a reason.' },
  { n: '03', title: 'Negotiate the changes', body: "We take the flagged clauses back to the club and negotiate them before signature — from the player's side of the table." },
];
---

<Layout title="Contract Analysis" description="Contract analysis — clause-by-clause review of a player's contract before signing, part of ProKickTalent representation.">

  <section class="ca">

    <section class="section">
      <div class="wrap">
        <p class="eyebrow eyebrow--gold" style="margin-bottom: 24px;">Representation · Contract analysis</p>
        <h1 class="display-2" style="max-width: 16ch;">Read every clause <em>before</em> you sign.</h1>
        <p class="lede" style="margin-top: 28px; max-width: 56ch;">A first professional contract is the moment a young player has the least leverage and the most to lose. We review every clause in plain language — term, wages, image rights, release, solidarity — and flag what needs to change before anyone signs.</p>
      </div>
    </section>

    <section class="section" style="padding-top: 0;">
      <div class="wrap">
        <div class="ca-doc">
          <div class="ca-clauses">
            <div class="ca-head">
              <div>
                <p class="ca-head__title">Contract review</p>
                <p class="ca-head__meta">First professional · CPL · 6 clauses</p>
              </div>
              <span class="ca-example">EXAMPLE</span>
            </div>
            {clauses.map((c) => (
              <div class="ca-clause">
                <span class="ca-clause__no">{c.no}</span>
                <div>
                  <p class="ca-clause__name">{c.name}</p>
                  <p class="ca-clause__note">{c.note}</p>
                </div>
                <span class={`ca-status ca-status--${c.status}`}>{c.label}</span>
              </div>
            ))}
          </div>

          <aside class="ca-summary">
            <div class="ca-verdict">
              <p class="ca-verdict__label">Verdict</p>
              <p class="ca-verdict__line">Signable — <b>after three changes.</b> Don't sign as drafted.”</p>
            </div>
            {terms.map((t) => (
              <div class="ca-term"><span class="ca-term__k">{t.k}</span><span class={`ca-term__v${t.flag ? ' is-flag' : ''}`}>{t.v}</span></div>
            ))}
            <div class="ca-tally">
              <span><i style="background: var(--data)"></i>3 clear</span>
              <span><i style="background: var(--gold)"></i>2 review</span>
              <span><i style="background: var(--ca-flag)"></i>1 flag</span>
            </div>
          </aside>
        </div>
        <p class="dim" style="font: 500 11px/1 var(--mono); margin-top: 16px;">EXAMPLE · illustrative review of a typical first professional contract. Not a real player file.</p>
      </div>
    </section>

    <section class="section section--hair">
      <div class="wrap">
        <div class="shead"><p class="eyebrow eyebrow--gold">How it works</p><h2>Three passes before a signature.</h2></div>
        <div class="ca-steps">
          {steps.map((s) => (
            <div class="ca-step"><span class="ca-step__n">{s.n}</span><h3>{s.title}</h3><p>{s.body}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--hair" style="text-align: center;">
      <div class="wrap wrap--narrow">
        <p class="eyebrow eyebrow--gold" style="margin-bottom: 24px;">Have an offer on the table?</p>
        <h2 class="display-3">Send it before you <em class="em">sign anything.</em></h2>
        <p class="lede" style="margin: 20px auto 32px; max-width: 46ch;">A contract review is free for players already in conversation with PKT. The point is protection, not pressure.</p>
        <a href="/contact" class="btn btn--primary">Request a contract review <span class="arr">→</span></a>
      </div>
    </section>

  </section>

</Layout>

<style>
  .ca { --ca-flag: #C0492F; }
  :global([data-theme="dark"]) .ca { --ca-flag: #E2705A; }

  .ca-doc { display: grid; grid-template-columns: 1.35fr 0.65fr; gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden; }
  .ca-clauses { background: var(--bg-2); }
  .ca-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; padding: 22px 26px; border-bottom: 1px solid var(--line); }
  .ca-head__title { font-family: var(--serif); font-weight: 500; font-size: 20px; margin: 0; }
  .ca-head__meta { font: 500 11px/1 var(--mono); color: var(--mute); margin: 4px 0 0; }
  .ca-example { font: 600 9px/1 var(--mono); letter-spacing: 0.12em; color: var(--mute); padding: 5px 8px; border: 1px solid var(--line-2); border-radius: var(--r-sm); }

  .ca-clause { display: grid; grid-template-columns: 64px 1fr auto; gap: 18px; padding: 20px 26px; border-bottom: 1px solid var(--line); align-items: start; }
  .ca-clause:last-child { border-bottom: none; }
  .ca-clause__no { font: 500 12px/1.5 var(--mono); color: var(--gold); }
  .ca-clause__name { font-family: var(--serif); font-weight: 500; font-size: 18px; margin: 0 0 4px; }
  .ca-clause__note { color: var(--mute); font-size: 14px; margin: 0; max-width: 48ch; }
  .ca-status { font: 600 10px/1 var(--sans); letter-spacing: 0.14em; text-transform: uppercase; padding: 6px 10px; border-radius: 100px; white-space: nowrap; display: inline-flex; align-items: center; gap: 7px; height: fit-content; }
  .ca-status::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .ca-status--clear  { color: var(--data); background: var(--gold-soft); }
  .ca-status--review { color: var(--gold); background: var(--gold-soft); }
  .ca-status--flag   { color: var(--ca-flag); background: rgba(192,73,47,0.12); }

  .ca-summary { background: var(--bg-3); padding: 26px; }
  .ca-verdict { padding-bottom: 22px; border-bottom: 1px solid var(--line); margin-bottom: 22px; }
  .ca-verdict__label { font: 600 10px/1 var(--sans); letter-spacing: 0.2em; text-transform: uppercase; color: var(--mute); margin: 0 0 12px; }
  .ca-verdict__line { font-family: var(--serif); font-style: italic; font-size: 21px; line-height: 1.35; margin: 0; }
  .ca-verdict__line b { color: var(--gold); font-style: normal; font-weight: 600; }
  .ca-term { display: flex; justify-content: space-between; align-items: baseline; padding: 11px 0; border-bottom: 1px solid var(--line); }
  .ca-term:last-child { border-bottom: none; }
  .ca-term__k { font: 500 11px/1.3 var(--sans); letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute); }
  .ca-term__v { font: 500 15px/1 var(--mono); color: var(--ink); }
  .ca-term__v.is-flag { color: var(--ca-flag); }
  .ca-tally { display: flex; gap: 18px; margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--line); }
  .ca-tally span { font: 500 12px/1 var(--mono); color: var(--mute); display: inline-flex; align-items: center; gap: 6px; }
  .ca-tally i { width: 7px; height: 7px; border-radius: 50%; }

  .ca-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden; }
  .ca-step { background: var(--bg); padding: 28px; }
  .ca-step__n { font: 500 12px/1 var(--mono); color: var(--gold); }
  .ca-step h3 { margin: 14px 0 8px; font-size: 22px; }
  .ca-step p { color: var(--mute); font-size: 14px; margin: 0; }

  @media (max-width: 880px) { .ca-doc { grid-template-columns: 1fr; } }
  @media (max-width: 760px) { .ca-steps { grid-template-columns: 1fr; } }
</style>
