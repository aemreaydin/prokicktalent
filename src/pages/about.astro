---
import Layout from '../layouts/Layout.astro';

const timeline = [
  { year: '2018', title: 'Player advisory begins.', body: 'Informally advising Ontario players and families on academy exposure, trial decisions, and the red flags families miss.' },
  { year: '2021', title: 'FIFA-aligned representation.', body: 'Representation built around FIFA standards — contract awareness, advocacy through trials and offers, professional independence.' },
  { year: '2024', title: 'ProKickTalent Sports Group founded.', body: 'Formalized as a dedicated agency: scouting, GPS, and advisory under one practice, based in Toronto, serving Ontario and Canada.' },
  { year: '2026', title: 'GPS analytics integrated.', body: 'Every active player file now pairs match scouting with GPS performance reporting — distance, sprint output, intensity, workload.' },
];
const creds = [
  { k: 'License', v: 'FIFA', d: 'Professional standards' },
  { k: 'Base', v: 'Toronto', d: 'Ontario · Canada' },
  { k: 'Focus', v: 'U17–U23', d: 'Serious players only' },
  { k: 'Method', v: 'Scout + GPS', d: 'Judgment + data' },
];
---

<Layout title="About" description="About ProKickTalent — a FIFA-licensed football agency built around evidence-led representation for U17–U23 Canadian footballers.">

  <section class="about-hero" data-theme="dark">
    <div class="photo"><span class="photo__tag">PLACEHOLDER · pitch / Toronto skyline</span></div>
    <div class="about-hero__scrim"></div>
    <div class="about-hero__in">
      <div class="wrap">
        <p class="eyebrow eyebrow--gold" style="margin-bottom: 22px;">Our story</p>
        <h1 class="display-1">Built from the <em>ground up.</em></h1>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="mission">
        <p class="eyebrow eyebrow--gold" style="margin-bottom: 24px;">Mission</p>
        <p class="lede" style="font-size: clamp(20px,2.4vw,26px); line-height: 1.5; color: var(--ink);">ProKickTalent represents serious U17–U23 Canadian footballers — independent of any club or academy, aligned to one outcome: the right next move for the player.</p>
        <p class="pullquote">Representation starts with evaluation. The player file is built before any introduction is made.</p>
        <p class="muted" style="font-size: 17px;">Families navigating academy exposure, college, semi-pro, CPL, and European trials deserve clear guidance grounded in scouting, GPS data, and FIFA-aligned representation standards. That clarity — not a quick introduction — is the product.</p>
      </div>
    </div>
  </section>

  <section class="section section--hair">
    <div class="wrap">
      <div class="shead"><p class="eyebrow eyebrow--gold">The path</p><h2>No shortcuts.</h2></div>
      <div class="tl">
        {timeline.map((t) => (
          <div class="tl__node">
            <p class="tl__year">{t.year}</p>
            <h3>{t.title}</h3>
            <p>{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="shead">
        <p class="eyebrow eyebrow--gold">Credentials</p>
        <h2>What the practice stands on.</h2>
        <p class="shead__lede">Every claim below is verifiable. Nothing else gets a card.</p>
      </div>
      <div class="creds">
        {creds.map((c) => (
          <div class="cred"><p class="eyebrow">{c.k}</p><b>{c.v}</b><span>{c.d}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--hair" style="text-align:center;">
    <div class="wrap wrap--narrow">
      <p class="eyebrow eyebrow--gold" style="margin-bottom: 24px;">Start the conversation</p>
      <h2 class="display-2">Let's talk about <em>your player.</em></h2>
      <p class="lede" style="margin: 20px auto 32px; max-width: 46ch;">Send the context, the questions, and the next decision in front of you.</p>
      <a href="/contact" class="btn btn--primary">Get in touch <span class="arr">→</span></a>
    </div>
  </section>

</Layout>

<style>
  .about-hero { position: relative; min-height: 64vh; display: flex; align-items: flex-end; overflow: hidden; }
  .about-hero .photo { position: absolute; inset: 0; }
  .about-hero__scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(0deg, rgba(11,11,12,0.9), transparent 70%), linear-gradient(90deg, rgba(11,11,12,0.7), transparent 60%); }
  .about-hero__in { position: relative; z-index: 2; width: 100%; padding-bottom: clamp(40px, 7vh, 88px); }

  .mission { max-width: 760px; }
  .pullquote { font-family: var(--serif); font-style: italic; font-size: clamp(26px, 3.4vw, 40px); line-height: 1.35; color: var(--ink); margin: 44px 0; padding: 28px 0; border-block: 1px solid var(--line); }
  .pullquote::before { content: "“"; color: var(--gold); }

  .tl { max-width: 760px; position: relative; padding-left: 56px; }
  .tl::before { content: ""; position: absolute; left: 13px; top: 10px; bottom: 10px; width: 1px; background: var(--line-2); }
  .tl__node { position: relative; padding-bottom: 40px; }
  .tl__node:last-child { padding-bottom: 0; }
  .tl__node::before { content: ""; position: absolute; left: -49px; top: 6px; width: 11px; height: 11px; border-radius: 50%; background: var(--gold); box-shadow: 0 0 0 4px var(--bg); }
  .tl__year { font: 500 12px/1 var(--mono); color: var(--gold); letter-spacing: 0.1em; }
  .tl__node h3 { margin: 12px 0 8px; }
  .tl__node p { color: var(--mute); font-size: 15px; margin: 0; }

  .creds { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden; }
  .cred { background: var(--bg); padding: 24px; }
  .cred .eyebrow { margin-bottom: 10px; }
  .cred b { font-family: var(--serif); font-weight: 500; font-size: 24px; display: block; }
  .cred span { color: var(--mute); font-size: 13px; }

  @media (max-width: 720px) { .creds { grid-template-columns: repeat(2, 1fr); } }
</style>
