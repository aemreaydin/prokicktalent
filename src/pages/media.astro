---
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const SIZE_CLASS = { regular: '', wide: 'wide', tall: 'tall', feature: 'big' };

const tiles = (await reader.collections.gallery.all())
  .map(({ entry: g }) => ({
    image: g.image,
    cap: g.caption,
    date: g.date,
    size: SIZE_CLASS[g.size] ?? '',
    order: g.order ?? 0,
  }))
  .sort((a, b) => a.order - b.order);

const press = (await reader.collections.press.all())
  .map(({ entry: p }) => ({
    src: p.source,
    date: p.date,
    title: p.headline,
    sub: p.subtitle,
    url: p.url || '#',
    order: p.order ?? 0,
  }))
  .sort((a, b) => a.order - b.order);
---

<Layout title="Media" description="Media and moments from ProKickTalent — matchdays, sessions, and press coverage.">

  <section class="md-hero" data-theme="dark">
    <div class="photo"><span class="photo__tag">PLACEHOLDER · matchday</span></div>
    <div class="md-hero__scrim"></div>
    <div class="md-hero__in wrap">
      <div>
        <p class="eyebrow eyebrow--gold" style="margin-bottom: 20px;">Gallery</p>
        <h1 class="display-1">Media &amp;<br/><em>moments.</em></h1>
      </div>
      <a href="https://instagram.com/prokicktalent" class="ig" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="17" cy="7" r="1" fill="currentColor"/></svg>
        Follow on Instagram
      </a>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="masonry">
        {tiles.map((t) => (
          <div class="tile" data-s={t.size}>
            <img class="tile__img" src={t.image} alt={t.cap} loading="lazy" />
            <div class="tile__cap"><p>{t.cap}</p><small>{t.date}</small></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--hair">
    <div class="wrap">
      <div class="shead"><p class="eyebrow eyebrow--gold">In the press</p><h2>Where PKT shows up.</h2></div>
      <div class="press__row">
        {press.map((p) => (
          <a href={p.url} class="press-card">
            <div class="press-card__top"><span class="press-card__src">{p.src}</span><span class="press-card__date">{p.date}</span></div>
            <h3>&ldquo;{p.title}&rdquo;</h3><p>{p.sub}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .md-hero { position: relative; min-height: 50vh; display: flex; align-items: flex-end; overflow: hidden; }
  .md-hero .photo { position: absolute; inset: 0; }
  .md-hero__scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(0deg, rgba(11,11,12,0.9), transparent 70%); }
  .md-hero__in { position: relative; z-index: 2; width: 100%; padding-bottom: clamp(32px,5vh,64px); display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap; }
  .ig { display:inline-flex; align-items:center; gap:9px; padding:11px 16px; border:1px solid rgba(236,234,227,0.3); border-radius:100px; color:#ECEAE3; font:600 11px/1 var(--sans); letter-spacing:0.14em; text-transform:uppercase; transition:border-color 250ms var(--ease); }
  .ig:hover { border-color: var(--gold); color: var(--gold); }
  .ig svg { color: var(--gold); }

  .masonry { display:grid; grid-template-columns:repeat(4,1fr); grid-auto-rows:170px; grid-auto-flow:dense; gap:12px; }
  .tile { position:relative; overflow:hidden; border-radius:var(--r-md); border:1px solid var(--line); transition:transform 300ms var(--ease),border-color 300ms; }
  .tile:hover{ transform:translateY(-2px); border-color:var(--line-2); }
  .tile[data-s="wide"]{grid-column:span 2;}
  .tile[data-s="tall"]{grid-row:span 2;}
  .tile[data-s="big"]{grid-column:span 2; grid-row:span 2;}
  .tile .photo{ position:absolute; inset:0; }
  .tile__img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .tile__cap { position:absolute; left:0; right:0; bottom:0; padding:28px 14px 14px; background:linear-gradient(0deg,rgba(0,0,0,0.85),transparent); opacity:0; transform:translateY(15%); transition:opacity 300ms var(--ease),transform 300ms; }
  .tile:hover .tile__cap { opacity:1; transform:none; }
  .tile__cap p{ margin:0; font:500 12px/1.4 var(--sans); color:#ECEAE3; }
  .tile__cap small{ display:block; margin-top:3px; font:500 10px/1 var(--mono); color:rgba(236,234,227,0.6); }
  .tile__badge { position:absolute; top:8px; left:8px; font:500 9px/1 var(--mono); color:rgba(236,234,227,0.7); padding:3px 6px; border:1px solid rgba(236,234,227,0.25); border-radius:3px; background:rgba(0,0,0,0.4); z-index:2; }

  .press__row { display:flex; gap:16px; overflow-x:auto; padding:8px 0 16px; scroll-snap-type:x mandatory; }
  .press-card { flex:0 0 320px; scroll-snap-align:start; padding:24px; border:1px solid var(--line); border-radius:var(--r-md); background:var(--bg-2); transition:border-color 250ms var(--ease); }
  .press-card:hover{ border-color:var(--line-2); }
  .press-card__top { display:flex; justify-content:space-between; align-items:baseline; }
  .press-card__src { font:500 10px/1 var(--mono); color:var(--gold); letter-spacing:0.1em; text-transform:uppercase; }
  .press-card__date { font:500 10px/1 var(--mono); color:var(--mute); }
  .press-card h3 { margin:16px 0 8px; font-size:21px; line-height:1.2; }
  .press-card p { margin:0; color:var(--mute); font-size:13px; }

  @media (max-width:900px){.masonry{grid-template-columns:repeat(3,1fr);}}
  @media (max-width:600px){.masonry{grid-template-columns:repeat(2,1fr);}}
</style>
