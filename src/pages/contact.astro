---
import Layout from '../layouts/Layout.astro';

const expect = [
  { t: '24-hour response', d: 'Every message gets a reply within one business day.' },
  { t: '20-minute intro call', d: "If there's a fit, a free call to understand the player's situation." },
  { t: 'What to send', d: 'Profile, position, age, current club, one recent match link — keeps the call focused.' },
  { t: 'Confidentiality', d: 'Nothing leaves the conversation without your written agreement.' },
  { t: "If we're not the fit", d: "We'll say so directly, and where possible suggest a better path." },
];
---

<Layout title="Contact" description="Get in touch with ProKickTalent — FIFA-licensed representation for U17–U23 Canadian footballers. 24-hour response.">

  <section class="ct-hero" data-theme="dark">
    <div class="photo"><span class="photo__tag">PLACEHOLDER · Toronto</span></div>
    <div class="ct-hero__scrim"></div>
    <div class="ct-hero__in">
      <div class="wrap">
        <p class="eyebrow eyebrow--gold" style="margin-bottom: 20px;">Start the conversation</p>
        <h1 class="display-1">Get in <em>touch.</em></h1>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="ct-grid">

        <form class="form" action="https://formspree.io/f/mlgpdwlp" method="POST">
          <h2>Send a message.</h2>
          <div class="field-row">
            <div class="field"><label for="name">Full name</label><input id="name" name="name" type="text" placeholder="Your full name" required /></div>
            <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" placeholder="you@example.com" required /></div>
          </div>
          <div class="field"><label for="interest">I'm interested in</label>
            <select id="interest" name="interest">
              <option>Player representation</option>
              <option>GPS performance analysis</option>
              <option>Scouting / evaluation</option>
              <option>Career / pathway guidance</option>
              <option>Contract review</option>
              <option>Press &amp; media enquiry</option>
            </select>
          </div>
          <div class="field"><label for="player">Player context (age / position / region)</label><input id="player" name="player" type="text" placeholder="U19 winger · 2007 · Ontario" /></div>
          <div class="field"><label for="message">Message</label><textarea id="message" name="message" placeholder="What's the next decision in front of you?" required></textarea></div>
          <button class="btn btn--primary" type="submit" style="width:100%;">Send message <span class="arr">→</span></button>
        </form>

        <aside class="expect">
          <h2>What to expect.</h2>
          <ul>
            {expect.map((e) => (<li><b>{e.t}</b><p>{e.d}</p></li>))}
          </ul>
          <div class="alt">
            <h3>Alternate contact</h3>
            <div class="alt__r"><span>Email</span><a href="mailto:burak@prokicktalent.com">burak@prokicktalent.com</a></div>
            <div class="alt__r"><span>Instagram</span><a href="https://instagram.com/prokicktalent" target="_blank" rel="noopener">@prokicktalent</a></div>
            <div class="alt__r"><span>Location</span><span class="muted">Toronto, Ontario</span></div>
          </div>
        </aside>

      </div>
    </div>
  </section>

</Layout>

<style>
  .ct-hero { position: relative; min-height: 46vh; display: flex; align-items: flex-end; overflow: hidden; }
  .ct-hero .photo { position: absolute; inset: 0; }
  .ct-hero__scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(0deg, rgba(11,11,12,0.9), transparent 70%); }
  .ct-hero__in { position: relative; z-index: 2; width: 100%; padding-bottom: clamp(32px,5vh,64px); }

  .ct-grid { display: grid; grid-template-columns: 0.58fr 0.42fr; gap: clamp(28px,5vw,56px); align-items: start; }
  .form { border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-2); padding: clamp(24px,4vw,36px); }
  .form h2 { font-size: 30px; margin: 0 0 24px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .expect { border: 1px solid var(--line); border-radius: var(--r-md); padding: clamp(24px,4vw,32px); }
  .expect h2 { font-size: 24px; margin: 0 0 22px; }
  .expect ul { list-style: none; padding: 0; margin: 0 0 28px; }
  .expect li { display: grid; grid-template-columns: 16px 1fr; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--line); }
  .expect li:last-child { border-bottom: none; }
  .expect li::before { content: ""; grid-row: 1/3; width: 7px; height: 7px; margin-top: 7px; border-radius: 50%; background: var(--data); box-shadow: 0 0 0 4px var(--gold-soft); }
  .expect li b { grid-column: 2; font: 600 14px/1.3 var(--sans); color: var(--ink); margin-bottom: 3px; display: block; }
  .expect li p { grid-column: 2; font-size: 13px; color: var(--mute); margin: 0; line-height: 1.5; max-width: none; }
  .alt { padding: 18px; background: var(--bg-3); border-radius: var(--r-sm); }
  .alt h3 { font: 600 11px/1 var(--sans); letter-spacing: 0.16em; text-transform: uppercase; color: var(--mute); margin: 0 0 12px; }
  .alt__r { display: flex; justify-content: space-between; padding: 7px 0; }
  .alt__r span { font-size: 13px; color: var(--ink); }
  .alt__r a { font-size: 13px; color: var(--gold); }

  @media (max-width: 880px) { .ct-grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .field-row { grid-template-columns: 1fr; } }
</style>
