---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Terms and Conditions" description="Terms and conditions for using the ProKickTalent Sports Group website.">
  <section class="section">
    <div class="wrap wrap--narrow legal">
      <p class="eyebrow eyebrow--gold" style="margin-bottom: 20px;">Legal</p>
      <h1 class="display-3">Terms &amp; Conditions</h1>
      <p class="dim mono" style="font-size: 12px; margin-top: 12px;">Last updated · March 2026</p>

      <p>By accessing and using the ProKickTalent Sports Group website, you accept these terms and conditions in full.</p>

      <h2>Use of website</h2>
      <p>This website is for informational purposes only. Content is provided without warranty of any kind. ProKickTalent reserves the right to change or remove content at any time.</p>

      <h2>Intellectual property</h2>
      <p>All content on this site — text, images, logos, and branding — is the property of ProKickTalent Sports Group. Unauthorized reproduction is prohibited.</p>

      <h2>Contact</h2>
      <p>Questions? <a href="/contact" class="link">Contact us</a>.</p>
    </div>
  </section>
</Layout>

<style>
  .legal { padding-top: 40px; }
  .legal h2 { font-size: 24px; margin: 40px 0 12px; }
  .legal p { color: var(--mute); margin: 0 0 14px; max-width: 64ch; }
  .legal .link { color: var(--gold); }
  .legal .link:hover { text-decoration: underline; }
</style>
